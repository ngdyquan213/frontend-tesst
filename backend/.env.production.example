APP_NAME=Secure Travel Booking Platform
ENVIRONMENT=production
DEBUG=false

SECRET_KEY=replace-with-production-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=7

DATABASE_URL=postgresql+psycopg2://app_user:replace-with-prod-db-password@postgres-primary.internal:5432/secure_travel_booking
PAYMENT_CALLBACK_SECRET=replace-with-production-payment-callback-secret
FRONTEND_BASE_URL=https://app.example.com

REDIS_URL=rediss://redis-primary.internal:6379/0
HOST_HTTP_PORT=8081
HOST_HTTPS_PORT=8443

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_REFRESH_PER_MINUTE=20
RATE_LIMIT_UPLOAD_PER_MINUTE=20
RATE_LIMIT_PAYMENT_CALLBACK_PER_MINUTE=50
RATE_LIMIT_DEFAULT_PER_MINUTE=120
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15

ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg

CORS_ORIGINS=https://app.example.com
TRUSTED_HOSTS=api.example.com,app,app:8000
OBSERVABILITY_PROTECTION_MODE=allowlist
OBSERVABILITY_ALLOWLIST=10.40.0.0/16,10.41.0.0/16

STORAGE_BACKEND=s3
LOCAL_STORAGE_BUCKET=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=10485760
OUTBOX_PROCESSING_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=30
OUTBOX_HEALTH_MODE=required
RUNTIME_MAINTENANCE_INTERVAL_SECONDS=60

EMAIL_WORKER_BACKEND=smtp
SMTP_HOST=smtp.internal
SMTP_PORT=587
SMTP_USERNAME=mailer
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

NOTIFICATION_WORKER_BACKEND=redis
NOTIFICATION_REDIS_CHANNEL=secure_travel.notifications.production
FORWARDED_ALLOW_IPS=10.20.0.0/16,10.21.0.0/16
PAYMENT_CALLBACK_SOURCE_ALLOWLIST=10.30.0.0/16,203.0.113.10/32

ALLOW_PAYMENT_SIMULATION=false

UPLOAD_MALWARE_SCAN_ENABLED=false
UPLOAD_MALWARE_SCAN_BACKEND=mock
CLAMAV_HOST=clamav.internal
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10

SECRET_SOURCE=secret_manager
SECRET_MANAGER_PROVIDER=aws-secrets-manager
SECRET_MANAGER_SECRET_ID=secure-travel-booking/production/app
SECRET_MANAGER_AWS_REGION=ap-southeast-1

S3_BUCKET_NAME=secure-travel-prod
S3_REGION=ap-southeast-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE_URL=https://api.stripe.com/v1
STRIPE_REQUEST_TIMEOUT_SECONDS=10
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

NGINX_SERVER_NAME=api.example.com
NGINX_TLS_ENABLED=true
NGINX_CERTS_DIR=infra/nginx/certs
NGINX_SSL_CERT_PATH=/etc/nginx/certs/tls.crt
NGINX_SSL_KEY_PATH=/etc/nginx/certs/tls.key
